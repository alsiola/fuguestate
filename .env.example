# Required — LLM features (dreaming, conflict detection, spirit quests) need this
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Server
PORT=4317
DB_PATH=./data/amts.sqlite
LOG_LEVEL=info

# Worker intervals (milliseconds)
CONSOLIDATION_INTERVAL_MS=300000    # 5 min — episode creation, belief promotion, dedup
SYNTHESIS_INTERVAL_MS=900000        # 15 min — pattern detection, repeated failure alerts
DECAY_INTERVAL_MS=600000            # 10 min — confidence decay, stale belief pruning
DREAM_INTERVAL_MS=3600000            # 60 min — sleep cycle (falling asleep → REM → optional spirit quest)
SLEEP_CYCLES_PER_QUEST=12            # spirit quest triggers every N sleep cycles

# Briefing
BRIEFING_TTL_SECONDS=300            # how long cached briefings last

# LLM
LLM_MODEL=claude-haiku-4-5-20251001  # model for background reasoning (dreams, conflict detection, etc.)
LLM_TIMEOUT_MS=30000

# Limits
MAX_BRIEFING_ITEMS=10
MAX_RETRIEVAL_RESULTS=20
HOOK_TIMEOUT_MS=100
